nextflow_process {

    name "Test Process STAINWARPY"
    script "../main.nf"
    process "STAINWARPY"

    tag "modules"
    tag "modules_nfcore"
    tag "stainwarpy"

    config "./nextflow.config"

    test("colon_tissue_local - ome.tif") {

        when {
            params {
                modules_args1 = "--channel-idx 0"
                modules_args2 = "--hne-px-sz 0.5023 --multiplexed-px-sz 0.209877 --feature-tform similarity"
                modules_args3 = "--hne-px-sz 0.5023 --multiplexed-px-sz 0.209877"
            }
            process {
                """
                input[0] = [
                    [ id:'sample1'],
                    file('../../../../../Masters-Thesis/data/hne_cropped_1.tif', checkIfExists: true),
                    file('../../../../../Masters-Thesis/data/dapi_cropped_1_3d.tif', checkIfExists: true),
                    file('../../../../../Masters-Thesis/data/hne_cropped_1_seg_masks.npy', checkIfExists: true)
                ]
                input[1] = 'multiplexed'
                input[2] = 'multiplexed'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() }
            )
        }

    }

    test("colon_tissue_local - ome.tif - stub") {

        options "-stub"

        when {
            params {
                modules_args1 = null
                modules_args2 = null
                modules_args3 = null
            }
            process {
                """
                input[0] = [
                    [ id:'sample1'],
                    file('../../../../../Masters-Thesis/data/hne_cropped_1.tif', checkIfExists: true),
                    file('../../../../../Masters-Thesis/data/dapi_cropped_1_3d.tif', checkIfExists: true),
                    file('../../../../../Masters-Thesis/data/hne_cropped_1_seg_masks.npy', checkIfExists: true)
                ]
                input[1] = 'multiplexed'
                input[2] = 'multiplexed'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
